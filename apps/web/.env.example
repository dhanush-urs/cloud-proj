# =============================================================================
# RepoBrain Web — Environment Variables
# =============================================================================
# Copy this to .env.local for local development.
# For Railway deployment, set these in the Railway service environment panel.
# =============================================================================

# ── API Proxy (Server-side — Next.js rewrites) ────────────────────────────────
# The URL the Next.js SERVER uses to forward /api/v1/* requests to the backend.
# On Railway: set this to your backend Railway public URL.
# Example: https://repobrain-api.up.railway.app
# If using Railway private networking: http://repobrain-api.railway.internal:8000
SERVER_API_BASE_URL=http://localhost:8000

# ── Public API URL (Client-side — only needed if you bypass the proxy) ────────
# Currently not used (all API calls go through the Next.js rewrite proxy).
# If you ever add direct client-side fetch to the backend, set this.
# NEXT_PUBLIC_API_BASE_URL=https://repobrain-api.up.railway.app

# ── Node Environment ──────────────────────────────────────────────────────────
NODE_ENV=production

# ── PORT (Railway injects this automatically) ─────────────────────────────────
# PORT=3000
