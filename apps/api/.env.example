# =============================================================================
# RepoBrain Monorepo — Root Environment Variables
# =============================================================================
# This file documents ALL variables used across backend + frontend.
# Each service (apps/api, apps/web) also has its own .env.example.
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development           # development | production
APP_NAME=RepoBrain
APP_VERSION=0.1.0

# ── Ports (local dev) ─────────────────────────────────────────────────────────
WEB_PORT=3000
API_PORT=8000

# ── URLs ──────────────────────────────────────────────────────────────────────
# Local dev:
WEB_URL=http://localhost:3000
API_URL=http://localhost:8000

# Railway production (fill in after deploying each service):
# FRONTEND_URL=https://repobrain-web.up.railway.app
# BACKEND_URL=https://repobrain-api.up.railway.app

# ── Backend Security ──────────────────────────────────────────────────────────
SECRET_KEY=change_me_super_secret_key
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS — comma-separated list of origins.
# Production: include your Railway frontend URL.
# Example: https://repobrain-web.up.railway.app,http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ── Frontend → Backend API connection ─────────────────────────────────────────
# Used by Next.js server-side to proxy /api/v1/* to the backend.
# Local Docker: http://api:8000 (internal Docker network)
# Railway: https://repobrain-api.up.railway.app (public URL) OR
#          http://repobrain-api.railway.internal:8000 (private networking)
SERVER_API_BASE_URL=http://localhost:8000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=repobrain
POSTGRES_USER=repobrain
POSTGRES_PASSWORD=repobrain
DATABASE_URL=postgresql+psycopg://repobrain:repobrain@postgres:5432/repobrain

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=repobrainneo4j

# ── LLM / Embeddings ──────────────────────────────────────────────────────────
LLM_PROVIDER=gemini           # gemini | none
EMBEDDING_PROVIDER=local      # local (sentence-transformers) | gemini
ENABLE_GEMINI=false           # set to true after adding a valid key

# SECURITY: Never hardcode your API key. Rotate if exposed.
GEMINI_API_KEY=your_key_here
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ── Repo Storage ──────────────────────────────────────────────────────────────
REPO_STORAGE_PATH=/app/data/repos
TEMP_STORAGE_PATH=/app/data/tmp

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
